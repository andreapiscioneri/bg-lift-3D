generator client {
  provider      = "prisma-client-js"
  // "native" per lo sviluppo locale; il target Debian serve al container di
  // produzione (node:20-bookworm-slim) altrimenti il query engine non è trovato.
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  TECNICO
  ADMIN
}

// Flusso di conferma ufficio tecnico:
// NONE → (utente invia) REQUESTED → (tecnico prende in carico) IN_REVIEW
// → (tecnico allega PDF) CERTIFIED. Un nuovo invio riparte da REQUESTED.
enum ReviewStatus {
  NONE
  REQUESTED
  IN_REVIEW
  CERTIFIED
}

enum CraneType {
  CINGOLATA
  RAGNO
  AUTOCARRATA
  TORRE
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  role         Role      @default(USER)
  active       Boolean   @default(true)
  projects     Project[]
  reviews      Project[] @relation("TechnicianReviews")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model CraneModel {
  id          String    @id @default(cuid())
  code        String    @unique
  name        String
  type        CraneType
  description String?
  glbUrl      String
  data        Json
  active      Boolean   @default(true)
  projects    Project[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Project {
  id           String     @id @default(cuid())
  name         String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  craneModel   CraneModel @relation(fields: [craneModelId], references: [id])
  craneModelId String
  config       Json?

  // Conferma ufficio tecnico
  reviewStatus       ReviewStatus @default(NONE)
  reviewRequestedAt  DateTime?
  reviewTechnician   User?        @relation("TechnicianReviews", fields: [reviewTechnicianId], references: [id], onDelete: SetNull)
  reviewTechnicianId String?
  certificateUrl     String?
  certifiedAt        DateTime?

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([userId])
  @@index([reviewStatus])
}
