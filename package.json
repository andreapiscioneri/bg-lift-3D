{
  "name": "bglift-3d",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "BGLift 3D — Web-tool 3D responsive per calcolo capacità gru BGLift",
  "scripts": {
    "dev": "concurrently -n web,api -c blue,green \"vite\" \"node --watch server/index.js\"",
    "dev:web": "vite",
    "dev:api": "node --watch server/index.js",
    "start": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "db:up": "docker compose up -d db",
    "db:migrate": "prisma migrate dev",
    "db:seed": "node prisma/seed.js",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6",
    "@react-three/drei": "^9.108.0",
    "@react-three/fiber": "^8.16.8",
    "bcryptjs": "^3.0.3",
    "comlink": "^4.4.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.18.1",
    "three": "^0.166.1",
    "zod": "^4.4.3",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^10.0.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.3",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "gltf-pipeline": "^4.3.1",
    "occt-import-js": "^0.0.23",
    "postcss": "^8.4.39",
    "prisma": "^6",
    "tailwindcss": "^3.4.6",
    "vite": "^5.3.4"
  }
}
