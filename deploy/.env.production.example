# Copiare in deploy/.env sul server e riempire con valori REALI e robusti.
# Generare i segreti con:  openssl rand -base64 36

# --- Database ---
POSTGRES_USER=bglift
POSTGRES_PASSWORD=CAMBIAMI_password_db_robusta
POSTGRES_DB=bglift

# --- App ---
# Segreto per firmare i JWT delle sessioni. DEVE essere lungo e casuale.
JWT_SECRET=CAMBIAMI_segreto_jwt_lungo_e_casuale

# Esegui il seed al primo avvio (crea admin@bglift.it / tecnico@bglift.it e i
# modelli gru). Metti "true" solo al primissimo deploy, poi rimetti "false".
SEED_ON_START=false
